{
  "dashboard": {
    "title": "k8s-guardian Dashboard",
    "tags": ["k8s-guardian", "kubernetes"],
    "timezone": "browser",
    "panels": [
      {
        "title": "HTTP Requests Total",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"k8s-guardian\"}[5m])",
            "legendFormat": "{{method}} {{route}} {{status_code}}"
          }
        ],
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        }
      },
      {
        "title": "HTTP Request Duration",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"k8s-guardian\"}[5m]))",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"k8s-guardian\"}[5m]))",
            "legendFormat": "99th percentile"
          }
        ],
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 8
        }
      },
      {
        "title": "Kubernetes API Requests",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(k8s_api_requests_total{job=\"k8s-guardian\"}[5m])",
            "legendFormat": "{{operation}} {{resource_type}}"
          }
        ],
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 12,
          "h": 8
        }
      },
      {
        "title": "Active WebSocket Connections",
        "type": "gauge",
        "targets": [
          {
            "expr": "active_websockets{job=\"k8s-guardian\"}",
            "legendFormat": "Active Connections"
          }
        ],
        "gridPos": {
          "x": 12,
          "y": 8,
          "w": 12,
          "h": 8
        }
      },
      {
        "title": "Cache Hit Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(cache_hits_total{job=\"k8s-guardian\"}[5m]) / (rate(cache_hits_total{job=\"k8s-guardian\"}[5m]) + rate(cache_misses_total{job=\"k8s-guardian\"}[5m]))",
            "legendFormat": "Hit Rate"
          }
        ],
        "gridPos": {
          "x": 0,
          "y": 16,
          "w": 12,
          "h": 8
        }
      },
      {
        "title": "Alerts Triggered",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(alerts_triggered_total{job=\"k8s-guardian\"}[5m])",
            "legendFormat": "{{severity}} {{type}}"
          }
        ],
        "gridPos": {
          "x": 12,
          "y": 16,
          "w": 12,
          "h": 8
        }
      }
    ],
    "schemaVersion": 27,
    "version": 1,
    "refresh": "30s"
  }
}
