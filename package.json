{
  "name": "k8s-guardian",
  "version": "1.0.0",
  "description": "A high-quality open-source Kubernetes运维 tool with CLI visualization and AI capabilities",
  "main": "src/index.js",
  "bin": {
    "k8s-guardian": "bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "dev": "node --watch bin/cli.js",
    "web": "node -e \"require('./src/web-server').startWebServer()\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "lint": "eslint src bin --ext .js",
    "lint:fix": "eslint src bin --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\" \"bin/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"bin/**/*.js\"",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "audit": "npm audit --audit-level=moderate",
    "clean": "rm -rf node_modules coverage dist build",
    "build": "npm run clean && npm install && npm run lint && npm run test"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "kubernetes",
    "k8s",
    "devops",
    "cli",
    "visualization",
    "ai"
  ],
  "author": "Open Source Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kudig-io/k8s-guardian.git"
  },
  "bugs": {
    "url": "https://github.com/kudig-io/k8s-guardian/issues"
  },
  "homepage": "https://github.com/kudig-io/k8s-guardian#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.20.0",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "chalk": "^4.1.2",
    "commander": "^9.5.0",
    "dotenv": "^16.0.3",
    "figlet": "^1.5.2",
    "inquirer": "^8.2.4",
    "axios": "^0.27.2",
    "express": "^4.18.2",
    "socket.io": "^4.5.4",
    "node-cron": "^3.0.2",
    "winston": "^3.11.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "eslint": "^8.19.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-n": "^15.2.4",
    "eslint-plugin-promise": "^6.0.0",
    "prettier": "^3.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.3",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/**/__tests__/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    },
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  }
}